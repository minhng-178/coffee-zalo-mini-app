ZALO_APP_ID=
ZALO_PRIVATE_KEY=
PORT=8080
# Comma-separated origin(s) allowed to call /orders (the mini app's dev/prod origin)
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=example:mongo://user:password@localhost:27017/dbname?authSource=admin

# --- WeChat (weixin/) ---
# All optional in dev: /wechat/* routes respond 501 instead of crashing when
# these are unset. See README.md's WeChat section for details.
WECHAT_APPID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
# PEM string of the merchant's APIv3 private key (apiclient_key.pem contents,
# newlines as \n). Takes precedence over WECHAT_MCH_PRIVATE_KEY_PATH below.
WECHAT_MCH_PRIVATE_KEY=
# Alternative to WECHAT_MCH_PRIVATE_KEY: a filesystem path to the PEM file.
WECHAT_MCH_PRIVATE_KEY_PATH=
WECHAT_MCH_CERT_SERIAL_NO=
WECHAT_APIV3_KEY=
# Public URL for POST /wechat/payment-callback, registered in the merchant platform
WECHAT_PAY_NOTIFY_URL=